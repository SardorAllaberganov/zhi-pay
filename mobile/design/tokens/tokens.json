{
  "$schema": "https://schemas.tokens-studio.io/tokens-studio.json",
  "$description": "ZhiPay Mobile — Foundation Tokens. Inherits brand + slate + semantic palettes from the admin dashboard (dashboard/src/styles/globals.css) so cross-surface parity holds. Mobile-specific additions: Display-tier typography sizes (44pt / 32pt), shadow-hero, and radius-large 20pt. Format: Tokens Studio / Style Dictionary compatible. Import into Figma via the 'Tokens Studio' plugin or convert via style-dictionary build.",
  "color": {
    "$description": "Color ramps. Each HSL value is identical in light and dark mode — what flips per mode is the semantic mapping in `color.semantic` below. See colors.md for contrast verification.",
    "brand": {
      "50":  { "$value": "hsl(210 80% 95%)", "$type": "color", "$description": "Subtle brand-tinted surface" },
      "100": { "$value": "hsl(210 78% 88%)", "$type": "color", "$description": "Hover surface for brand-tinted rows" },
      "200": { "$value": "hsl(210 76% 76%)", "$type": "color", "$description": "Disabled-on-brand fill; hero gradient stop" },
      "300": { "$value": "hsl(210 70% 64%)", "$type": "color", "$description": "Decorative only; too light for body text on slate-50" },
      "400": { "$value": "hsl(210 66% 53%)", "$type": "color", "$description": "Dark-mode focus ring" },
      "500": { "$value": "hsl(209 77% 45%)", "$type": "color", "$description": "Dark-mode primary CTA fill" },
      "600": { "$value": "hsl(209 90% 39%)", "$type": "color", "$description": "ANCHOR — light-mode primary CTA, hero amount, focus ring, status processing/completed" },
      "700": { "$value": "hsl(211 91% 32%)", "$type": "color", "$description": "CTA pressed state" },
      "800": { "$value": "hsl(213 89% 25%)", "$type": "color", "$description": "Hero-card gradient end stop" },
      "900": { "$value": "hsl(215 86% 18%)", "$type": "color", "$description": "Reserved" },
      "950": { "$value": "hsl(217 92% 12%)", "$type": "color", "$description": "Reserved" }
    },
    "slate": {
      "50":  { "$value": "hsl(210 40% 98%)", "$type": "color", "$description": "Light-mode background" },
      "100": { "$value": "hsl(210 40% 96%)", "$type": "color", "$description": "Secondary fill, sheet handle" },
      "200": { "$value": "hsl(214 32% 91%)", "$type": "color", "$description": "Light-mode border / divider; input border" },
      "300": { "$value": "hsl(213 27% 84%)", "$type": "color", "$description": "Disabled border; secondary outline" },
      "400": { "$value": "hsl(215 20% 65%)", "$type": "color", "$description": "Decorative meta; dark-mode muted-foreground" },
      "500": { "$value": "hsl(215 16% 47%)", "$type": "color", "$description": "Light-mode muted-foreground" },
      "600": { "$value": "hsl(215 19% 35%)", "$type": "color", "$description": "Dark-mode body text alternative" },
      "700": { "$value": "hsl(215 25% 27%)", "$type": "color", "$description": "Dark-mode card stroke" },
      "800": { "$value": "hsl(217 33% 17%)", "$type": "color", "$description": "Dark-mode border / divider" },
      "900": { "$value": "hsl(222 47% 11%)", "$type": "color", "$description": "Light-mode foreground; dark-mode card" },
      "950": { "$value": "hsl(229 84% 5%)", "$type": "color", "$description": "Dark-mode background" }
    },
    "success": {
      "50":  { "$value": "hsl(138 76% 97%)", "$type": "color" },
      "600": { "$value": "hsl(142 71% 45%)", "$type": "color" },
      "700": { "$value": "hsl(142 76% 36%)", "$type": "color" }
    },
    "warning": {
      "50":  { "$value": "hsl(48 100% 96%)", "$type": "color" },
      "600": { "$value": "hsl(32 95% 44%)",  "$type": "color" },
      "700": { "$value": "hsl(26 90% 37%)",  "$type": "color" }
    },
    "danger": {
      "50":  { "$value": "hsl(0 86% 97%)", "$type": "color", "$description": "RESERVED — never used as primary accent. See colors.md." },
      "600": { "$value": "hsl(0 72% 51%)", "$type": "color", "$description": "RESERVED — destructive CTA only" },
      "700": { "$value": "hsl(0 74% 42%)", "$type": "color", "$description": "RESERVED" }
    },
    "white": { "$value": "hsl(0 0% 100%)", "$type": "color" },

    "semantic": {
      "$description": "Role-anchored aliases. Resolve to different ramp stops per mode. Use these in screens — not raw brand-600 etc — wherever a role exists.",
      "light": {
        "background":             { "$value": "{color.slate.50}",  "$type": "color" },
        "foreground":             { "$value": "{color.slate.900}", "$type": "color" },
        "card":                   { "$value": "{color.white}",     "$type": "color" },
        "card-foreground":        { "$value": "{color.slate.900}", "$type": "color" },
        "popover":                { "$value": "{color.white}",     "$type": "color" },
        "popover-foreground":     { "$value": "{color.slate.900}", "$type": "color" },
        "primary":                { "$value": "{color.brand.600}", "$type": "color" },
        "primary-foreground":     { "$value": "{color.white}",     "$type": "color" },
        "secondary":              { "$value": "{color.slate.100}", "$type": "color" },
        "secondary-foreground":   { "$value": "{color.slate.900}", "$type": "color" },
        "muted":                  { "$value": "{color.slate.100}", "$type": "color" },
        "muted-foreground":       { "$value": "{color.slate.500}", "$type": "color" },
        "accent":                 { "$value": "{color.slate.100}", "$type": "color" },
        "accent-foreground":      { "$value": "{color.slate.900}", "$type": "color" },
        "destructive":            { "$value": "{color.danger.600}","$type": "color" },
        "destructive-foreground": { "$value": "{color.white}",     "$type": "color" },
        "border":                 { "$value": "{color.slate.200}", "$type": "color" },
        "input":                  { "$value": "{color.slate.200}", "$type": "color" },
        "ring":                   { "$value": "{color.brand.600}", "$type": "color" }
      },
      "dark": {
        "background":             { "$value": "{color.slate.950}", "$type": "color" },
        "foreground":             { "$value": "{color.slate.100}", "$type": "color" },
        "card":                   { "$value": "{color.slate.900}", "$type": "color" },
        "card-foreground":        { "$value": "{color.slate.100}", "$type": "color" },
        "popover":                { "$value": "{color.slate.900}", "$type": "color" },
        "popover-foreground":     { "$value": "{color.slate.100}", "$type": "color" },
        "primary":                { "$value": "{color.brand.500}", "$type": "color" },
        "primary-foreground":     { "$value": "{color.white}",     "$type": "color" },
        "secondary":              { "$value": "{color.slate.800}", "$type": "color" },
        "secondary-foreground":   { "$value": "{color.slate.100}", "$type": "color" },
        "muted":                  { "$value": "{color.slate.800}", "$type": "color" },
        "muted-foreground":       { "$value": "{color.slate.400}", "$type": "color" },
        "accent":                 { "$value": "{color.slate.800}", "$type": "color" },
        "accent-foreground":      { "$value": "{color.slate.100}", "$type": "color" },
        "destructive":            { "$value": "{color.danger.600}","$type": "color" },
        "destructive-foreground": { "$value": "{color.white}",     "$type": "color" },
        "border":                 { "$value": "{color.slate.800}", "$type": "color" },
        "input":                  { "$value": "{color.slate.800}", "$type": "color" },
        "ring":                   { "$value": "{color.brand.400}", "$type": "color" }
      }
    }
  },

  "typography": {
    "$description": "Mobile lifts display sizes higher than admin's web scale. Body floor is 14pt for flowing text and buttons (LESSON 2026-05-01); 13pt label is reserved for chips/kbd/uppercase only.",
    "fontFamily": {
      "sans": { "$value": "Inter, -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, system-ui, sans-serif", "$type": "fontFamilies" },
      "mono": { "$value": "'JetBrains Mono', 'SF Mono', Menlo, monospace", "$type": "fontFamilies" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "fontWeights" },
      "medium":   { "$value": "500", "$type": "fontWeights" },
      "semibold": { "$value": "600", "$type": "fontWeights" },
      "bold":     { "$value": "700", "$type": "fontWeights" }
    },
    "fontSize": {
      "display-1":  { "$value": "44px", "$type": "fontSizes" },
      "display-2":  { "$value": "32px", "$type": "fontSizes" },
      "heading":    { "$value": "22px", "$type": "fontSizes" },
      "body":       { "$value": "16px", "$type": "fontSizes" },
      "body-small": { "$value": "14px", "$type": "fontSizes" },
      "label":      { "$value": "13px", "$type": "fontSizes" }
    },
    "lineHeight": {
      "display-1":  { "$value": "48px", "$type": "lineHeights" },
      "display-2":  { "$value": "38px", "$type": "lineHeights" },
      "heading":    { "$value": "28px", "$type": "lineHeights" },
      "body":       { "$value": "24px", "$type": "lineHeights" },
      "body-small": { "$value": "20px", "$type": "lineHeights" },
      "label":      { "$value": "18px", "$type": "lineHeights" }
    },
    "letterSpacing": {
      "display-1":   { "$value": "-0.02em",  "$type": "letterSpacing" },
      "display-2":   { "$value": "-0.015em", "$type": "letterSpacing" },
      "heading":     { "$value": "-0.01em",  "$type": "letterSpacing" },
      "body":        { "$value": "0",        "$type": "letterSpacing" },
      "body-small":  { "$value": "0",        "$type": "letterSpacing" },
      "label-upper": { "$value": "0.04em",   "$type": "letterSpacing", "$description": "Apply ONLY when the label is uppercased" }
    },
    "role": {
      "$description": "Composed text-style tokens — use these in Figma/Tokens Studio as the per-text-element binding. Each composes fontFamily / fontWeight / fontSize / lineHeight / letterSpacing.",
      "display-1": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.bold}",
          "fontSize":      "{typography.fontSize.display-1}",
          "lineHeight":    "{typography.lineHeight.display-1}",
          "letterSpacing": "{typography.letterSpacing.display-1}"
        }
      },
      "display-2": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.bold}",
          "fontSize":      "{typography.fontSize.display-2}",
          "lineHeight":    "{typography.lineHeight.display-2}",
          "letterSpacing": "{typography.letterSpacing.display-2}"
        }
      },
      "heading": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.semibold}",
          "fontSize":      "{typography.fontSize.heading}",
          "lineHeight":    "{typography.lineHeight.heading}",
          "letterSpacing": "{typography.letterSpacing.heading}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.regular}",
          "fontSize":      "{typography.fontSize.body}",
          "lineHeight":    "{typography.lineHeight.body}",
          "letterSpacing": "{typography.letterSpacing.body}"
        }
      },
      "body-small": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.regular}",
          "fontSize":      "{typography.fontSize.body-small}",
          "lineHeight":    "{typography.lineHeight.body-small}",
          "letterSpacing": "{typography.letterSpacing.body-small}"
        }
      },
      "label": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.fontFamily.sans}",
          "fontWeight":    "{typography.fontWeight.medium}",
          "fontSize":      "{typography.fontSize.label}",
          "lineHeight":    "{typography.lineHeight.label}",
          "letterSpacing": "{typography.letterSpacing.body}"
        }
      }
    }
  },

  "spacing": {
    "$description": "8pt base. Mobile page-gutter default = space-4 (16pt); hero screens widen to space-5 (20pt). Tap targets ≥ 44pt regardless of visual size — pad the tap area, don't shrink the visual.",
    "0":  { "$value": "0px",  "$type": "spacing" },
    "1":  { "$value": "4px",  "$type": "spacing" },
    "2":  { "$value": "8px",  "$type": "spacing" },
    "3":  { "$value": "12px", "$type": "spacing" },
    "4":  { "$value": "16px", "$type": "spacing" },
    "5":  { "$value": "20px", "$type": "spacing" },
    "6":  { "$value": "24px", "$type": "spacing" },
    "7":  { "$value": "32px", "$type": "spacing" },
    "8":  { "$value": "40px", "$type": "spacing" },
    "9":  { "$value": "48px", "$type": "spacing" },
    "10": { "$value": "64px", "$type": "spacing" },
    "11": { "$value": "80px", "$type": "spacing", "$description": "Reserved — currently unused at mobile" },
    "12": { "$value": "96px", "$type": "spacing", "$description": "Reserved — currently unused at mobile" }
  },

  "radius": {
    "$description": "Four named stops + pill. Mobile bumps the smallest stop to 8pt (admin uses 4pt) so 48pt-tall inputs don't read tinny.",
    "sm":   { "$value": "8px",    "$type": "borderRadius", "$description": "Inputs, chips, toast" },
    "md":   { "$value": "12px",   "$type": "borderRadius", "$description": "Cards, buttons, banners" },
    "lg":   { "$value": "20px",   "$type": "borderRadius", "$description": "Sheets (top corners), hero card-as-object, receipt amount card" },
    "pill": { "$value": "9999px", "$type": "borderRadius", "$description": "Tier badges, status chips, segmented control track + thumb, avatar" }
  },

  "shadow": {
    "$description": "Three elevations + hero. Dark-mode shadows lean on opacity, not blur. Limit one shadow-hero per screen.",
    "light": {
      "sm":   { "$value": { "x": "0", "y": "1px",  "blur": "2px",  "spread": "0",     "color": "rgb(0 0 0 / 0.04)" }, "$type": "boxShadow" },
      "md":   { "$value": [
        { "x": "0", "y": "4px",  "blur": "12px", "spread": "-2px",  "color": "rgb(0 0 0 / 0.08)" },
        { "x": "0", "y": "1px",  "blur": "3px",  "spread": "-1px",  "color": "rgb(0 0 0 / 0.04)" }
      ], "$type": "boxShadow" },
      "lg":   { "$value": [
        { "x": "0", "y": "12px", "blur": "32px", "spread": "-8px",  "color": "rgb(0 0 0 / 0.12)" },
        { "x": "0", "y": "4px",  "blur": "12px", "spread": "-2px",  "color": "rgb(0 0 0 / 0.06)" }
      ], "$type": "boxShadow" },
      "hero": { "$value": [
        { "x": "0", "y": "24px", "blur": "48px", "spread": "-12px", "color": "hsl(215 86% 18% / 0.20)" },
        { "x": "0", "y": "8px",  "blur": "24px", "spread": "-4px",  "color": "hsl(213 89% 25% / 0.12)" }
      ], "$type": "boxShadow", "$description": "Brand-tinted lift for home card-as-object + receipt amount card. Limit ONE per screen." }
    },
    "dark": {
      "sm":   { "$value": { "x": "0", "y": "1px",  "blur": "2px",  "spread": "0",     "color": "rgb(0 0 0 / 0.40)" }, "$type": "boxShadow" },
      "md":   { "$value": [
        { "x": "0", "y": "4px",  "blur": "12px", "spread": "-2px",  "color": "rgb(0 0 0 / 0.50)" },
        { "x": "0", "y": "1px",  "blur": "3px",  "spread": "-1px",  "color": "rgb(0 0 0 / 0.30)" }
      ], "$type": "boxShadow" },
      "lg":   { "$value": [
        { "x": "0", "y": "12px", "blur": "32px", "spread": "-8px",  "color": "rgb(0 0 0 / 0.60)" },
        { "x": "0", "y": "4px",  "blur": "12px", "spread": "-2px",  "color": "rgb(0 0 0 / 0.40)" }
      ], "$type": "boxShadow" },
      "hero": { "$value": [
        { "x": "0", "y": "24px", "blur": "48px", "spread": "-12px", "color": "hsl(217 92% 12% / 0.65)" },
        { "x": "0", "y": "8px",  "blur": "24px", "spread": "-4px",  "color": "hsl(215 86% 18% / 0.45)" }
      ], "$type": "boxShadow" }
    }
  },

  "motion": {
    "$description": "Quiet, purposeful motion. prefers-reduced-motion collapses to instantaneous. Inherits admin's two ease curves; adds ease-exit for sheet/modal dismiss. Default duration bumps from admin's 180ms to 220ms because hand interaction reads better at slightly longer durations than mouse.",
    "duration": {
      "fast": { "$value": "140ms", "$type": "duration", "$description": "Press-state, chip hover, toggle thumb" },
      "base": { "$value": "220ms", "$type": "duration", "$description": "DEFAULT. Sheet open/close, toast in, banner reveal, segmented switch" },
      "slow": { "$value": "320ms", "$type": "duration", "$description": "Modal open, sheet snap-point change, full-screen page transition" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)",   "$type": "cubicBezier", "$description": "DEFAULT. Enter from offscreen, fade-in, slide-up. Inherited from admin." },
      "emphasized": { "$value": "cubic-bezier(0.2, 0, 0, 1.2)", "$type": "cubicBezier", "$description": "Button press release, card-as-object reveal" },
      "exit":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier", "$description": "Sheet close, modal dismiss, leave-to-offscreen" }
    }
  }
}
